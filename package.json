{
  "name": "trmnl",
  "version": "1.2.0",
  "description": "DeepL-powered terminal translator. Runs standalone as a REPL and as a Claude Code plugin (slash commands + auto-translate hook).",
  "bin": {
    "trmnl": "bin/trmnl.js"
  },
  "scripts": {
    "start": "node bin/trmnl.js"
  },
  "keywords": [
    "translate",
    "translation",
    "cli",
    "deepl",
    "terminal",
    "repl",
    "chinese",
    "japanese",
    "korean",
    "clipboard",
    "claude-code",
    "claude-code-plugin"
  ],
  "author": "vauugnn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vauugnn/TRmnl.git"
  },
  "bugs": {
    "url": "https://github.com/vauugnn/TRmnl/issues"
  },
  "homepage": "https://github.com/vauugnn/TRmnl#readme",
  "engines": {
    "node": ">=14"
  },
  "files": [
    "bin/",
    "lib/",
    ".claude-plugin/",
    "commands/",
    "hooks/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "clipboardy": "^2.3.0",
    "deepl-node": "^1.24.0"
  }
}
